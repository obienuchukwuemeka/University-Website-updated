    <!-- Breadcrumb -->
    <div class="breadcrumb">
        <a href="index.html">Home</a> &nbsp;›&nbsp;
        <a href="course.html">Courses</a> &nbsp;›&nbsp;
        Degree Programmes
    </div>

    <!-- Intro -->
    <div class="degree-intro">
        <h1>Explore Our <span>12 Faculties</span></h1>
        <p>Our undergraduate degree programmes span science, technology, humanities, law, health, and business. Each faculty is staffed by world-class academics committed to producing graduates ready for the global stage.</p>

        <div class="degree-stats">
            <div class="stat-item">
                <h3>12</h3>
                <p>Faculties</p>
            </div>
            <div class="stat-item">
                <h3>60+</h3>
                <p>Departments</p>
            </div>
            <div class="stat-item">
                <h3>4–6 yrs</h3>
                <p>Programme Duration</p>
            </div>
            <div class="stat-item">
                <h3>5 Credits</h3>
                <p>Minimum O'Level Entry</p>
            </div>
        </div>
    </div>

    <!-- Filter Tabs -->
    <div class="faculty-filter">
        <button class="filter-btn active" onclick="filterFaculties('all', this)">All Faculties</button>
        <button class="filter-btn" onclick="filterFaculties('health', this)">Health Sciences</button>
        <button class="filter-btn" onclick="filterFaculties('science', this)">Pure & Applied Sciences</button>
        <button class="filter-btn" onclick="filterFaculties('humanities', this)">Humanities</button>
        <button class="filter-btn" onclick="filterFaculties('management', this)">Management</button>
        <button class="filter-btn" onclick="filterFaculties('engineering', this)">Engineering</button>
    </div>

