                    <div class="faculty-icon"><i class="fa-solid fa-microscope"></i></div>
                    <h3>Faculty of Basic Medical Sciences</h3>
                    <ul class="dept-list">
                        <li>Biochemistry</li>
                        <li>Anatomy</li>
                        <li>Physiology</li>
                        <li>Medical Laboratory Science</li>
                    </ul>
                </div>
                <div class="faculty-card-footer">
