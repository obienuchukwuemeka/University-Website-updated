    <!-- Admission Requirements -->
    <div class="requirements">
        <h2>Admission Requirements</h2>
        <div class="req-grid">

            <div class="req-card">
                <div class="req-icon"><i class="fa-solid fa-user-graduate"></i></div>
                <h4>First Degree</h4>
                <p>A relevant Bachelor's degree with at least Second Class Lower (2:2) or CGPA of 3.50 on a 5-point scale from a recognised university</p>
            </div>

            <div class="req-card">
                <div class="req-icon"><i class="fa-solid fa-file-lines"></i></div>
                <h4>Academic Transcripts</h4>
                <p>Official certified transcripts of all previous academic qualifications sent directly from the awarding institution</p>
            </div>

            <div class="req-card">
                <div class="req-icon"><i class="fa-solid fa-people-arrows"></i></div>
                <h4>Reference Letters</h4>
                <p>Two academic reference letters from qualified university lecturers or professionals in your field of study</p>
            </div>

            <div class="req-card">
                <div class="req-icon"><i class="fa-solid fa-money-bill-wave"></i></div>
                <h4>Application Fee</h4>
                <p>Non-refundable fee of ₦30,000 paid via ndufees.com before completing the online form at postgraduate.nduportal.com</p>
            </div>

        </div>
