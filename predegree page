    <!-- Admission Requirements -->
    <div class="requirements">
        <h2>Admission Requirements</h2>
        <div class="req-grid">

            <div class="req-card">
                <div class="req-icon"><i class="fa-solid fa-file-lines"></i></div>
                <h4>O'Level Result</h4>
                <p>Minimum of 5 credit passes including English Language and Mathematics in not more than 2 sittings (WAEC, NECO, or NABTEB)</p>
            </div>

            <div class="req-card">
                <div class="req-icon"><i class="fa-solid fa-id-card"></i></div>
                <h4>Identification Documents</h4>
                <p>Valid Age Declaration or Birth Certificate plus an LGA Identification Letter confirming your state of origin</p>
            </div>

            <div class="req-card">
                <div class="req-icon"><i class="fa-solid fa-people-arrows"></i></div>
                <h4>Reference Letters</h4>
                <p>Two reference letters signed by two qualified referees (e.g. a teacher, pastor, imam, or community leader)</p>
            </div>

        </div>
